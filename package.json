{
  "name": "@arsasatria/ccw",
  "version": "2.0.0",
  "description": "Use Claude Code without an Anthropics account and route it to another LLM provider",
  "private": true,
  "scripts": {
    "build": "node scripts/build.js",
    "build:cli": "pnpm --filter @ccw/cli build",
    "build:server": "pnpm --filter @ccw/server build",
    "build:ui": "pnpm --filter @ccw/ui build",
    "build:docs": "pnpm --filter ccw-docs build",
    "release": "pnpm build && bash scripts/release.sh all",
    "release:npm": "bash scripts/release.sh npm",
    "release:docker": "bash scripts/release.sh docker",
    "dev:cli": "pnpm --filter @ccw/cli dev",
    "dev:server": "pnpm --filter @ccw/server dev",
    "dev:ui": "pnpm --filter @ccw/ui dev",
    "dev:docs": "pnpm --filter ccw-docs start",
    "serve:docs": "pnpm --filter ccw-docs serve"
  },
  "bin": {
    "ccr": "dist/cli.js"
  },
  "keywords": [
    "claude",
    "code",
    "router",
    "llm",
    "anthropic"
  ],
  "author": "musistudio",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.15",
    "esbuild": "^0.25.1",
    "shx": "^0.4.0",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
