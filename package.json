{
  "name": "ccw",
  "version": "1.0.0",
  "description": "Claude Code Wrapper — fixed fork (interleaved text+tool_use streaming bug)",
  "scripts": {
    "build": "pnpm build:shared && pnpm build:core && pnpm build:server && pnpm build:cli && pnpm build:ui",
    "build:core": "pnpm --filter @musistudio/llms build",
    "build:shared": "pnpm --filter @ccw/shared build",
    "build:cli": "pnpm --filter @ccw/cli build",
    "build:server": "pnpm --filter @ccw/server build",
    "build:ui": "pnpm --filter @ccw/ui build",
    "build:docs": "pnpm --filter ccw-docs build",
    "release": "pnpm build && bash scripts/release.sh all",
    "release:npm": "bash scripts/release.sh npm",
    "release:docker": "bash scripts/release.sh docker",
    "dev:cli": "pnpm --filter @ccw/cli dev",
    "dev:server": "pnpm --filter @ccw/server dev",
    "dev:ui": "pnpm --filter @ccw/ui dev",
    "dev:core": "pnpm --filter @musistudio/llms dev",
    "dev:docs": "pnpm --filter ccw-docs start",
    "serve:docs": "pnpm --filter ccw-docs serve"
  },
  "bin": {
    "ccw": "dist/cli.js"
  },
  "keywords": [
    "claude",
    "code",
    "router",
    "llm",
    "anthropic"
  ],
  "author": "arsasatria",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arsasatria/ccw.git"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "esbuild": "^0.25.1",
    "shx": "^0.4.0",
    "typescript": "^5.8.2"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
